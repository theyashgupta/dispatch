{
  "name": "dispatch",
  "version": "1.5.0",
  "description": "A local kanban board that turns Linear tickets into live Claude Code agent sessions - one git worktree per ticket, real terminals in the browser.",
  "license": "MIT",
  "author": "Yash Gupta",
  "repository": {
    "type": "git",
    "url": "https://github.com/theyashgupta/dispatch.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"tsx watch src/server/bootstrap/index.ts\" \"vite\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deadcode": "knip",
    "replay-gate": "tsx scripts/replay-watcher.ts --check",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run deadcode && npm run replay-gate"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "better-sqlite3": "12.11.1",
    "express": "5.2.1",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "write-file-atomic": "8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/write-file-atomic": "4.0.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-boundaries": "7.0.1",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-jsdoc": "63.0.12",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "knip": "6.24.0",
    "prettier": "3.9.4",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3"
  }
}
