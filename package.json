{
  "name": "@theyashgupta/dispatch",
  "version": "2.5.3",
  "description": "A local kanban board that turns Linear tickets into live Claude Code agent sessions - one git worktree per ticket, real terminals in the browser.",
  "keywords": [
    "kanban",
    "linear",
    "claude-code",
    "agent",
    "tmux",
    "ttyd",
    "worktree",
    "cli",
    "localhost"
  ],
  "license": "MIT",
  "author": "Yash Gupta",
  "homepage": "https://github.com/theyashgupta/dispatch#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/theyashgupta/dispatch.git"
  },
  "bugs": {
    "url": "https://github.com/theyashgupta/dispatch/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.22"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "dispatch": "dist/server/bootstrap/cli.js"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"tsx watch src/server/bootstrap/index.ts\" \"vite\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deadcode": "knip",
    "build:web": "vite build",
    "analyze": "ANALYZE=1 vite build",
    "build:server": "tsc -p tsconfig.build.json",
    "build": "npm run build:web && npm run build:server",
    "start": "NODE_ENV=production node dist/server/bootstrap/index.js",
    "replay-gate": "tsx scripts/replay-watcher.ts --check",
    "sim": "node scripts/fresh-env-sim.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run deadcode && npm run replay-gate",
    "prepack": "npm run build"
  },
  "dependencies": {
    "express": "5.2.1",
    "uqr": "0.1.3",
    "write-file-atomic": "8.0.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "6.3.1",
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/write-file-atomic": "4.0.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-boundaries": "7.0.1",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-jsdoc": "63.0.12",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "knip": "6.24.0",
    "lucide-react": "1.23.0",
    "prettier": "3.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "rollup-plugin-visualizer": "7.0.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3"
  }
}
